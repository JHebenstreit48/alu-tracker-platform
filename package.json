{
  "name": "alu-tracker-car-data",
  "version": "1.0.0",
  "description": "Database for all ALU car data",
  "main": "dist/index.js",
  "scripts": {
    "start": "ts-node -r tsconfig-paths/register src/server.ts",
    "dev": "ts-node -r tsconfig-paths/register src/server.ts",

    "seed:cars": "ts-node -r tsconfig-paths/register src/scripts/DatabaseImports/importCars.ts",
    "seed:cars:selected": "ts-node -r tsconfig-paths/register src/scripts/DatabaseImports/importCarsSelected.ts",

    "seed:cars:v2": "ts-node -r tsconfig-paths/register src/scripts/DatabaseImports/importCarsV2.ts",
    "seed:cars:selected:v2": "ts-node -r tsconfig-paths/register src/scripts/DatabaseImports/importCarsSelectedV2.ts",

    "seed:prune:legacy-stats": "ts-node -r tsconfig-paths/register src/scripts/DatabaseImports/Cars/pruneLegacyStats.ts",
    "seed:prune:legacy-stats:all": "npm run seed:prune:legacy-stats -- --all",
    "seed:prune:legacy-stats:all:apply": "npm run seed:prune:legacy-stats -- --all --apply",

    "seed:images": "ts-node -r tsconfig-paths/register src/scripts/DatabaseImports/importCarImages.ts",
    "seed:brands": "ts-node -r tsconfig-paths/register src/scripts/DatabaseImports/importBrands.ts",
    "seed:garage-levels": "ts-node -r tsconfig-paths/register src/scripts/DatabaseImports/importGarageLevels.ts",
    
    "seed:blueprint-credits": "ts-node -r tsconfig-paths/register src/scripts/DatabaseImports/LegendStore/importBlueprintCredits.ts",
    "seed:trade-coins": "ts-node -r tsconfig-paths/register src/scripts/DatabaseImports/LegendStore/importTradeCoins.ts",
    "seed:legend-store": "ts-node -r tsconfig-paths/register src/scripts/DatabaseImports/importLegendStore.ts",

    "seed:normalize": "ts-node -r tsconfig-paths/register src/scripts/DatabaseImports/Cars/seedNormalize.ts",
    "seed:normalize:apply": "ts-node -r tsconfig-paths/register src/scripts/DatabaseImports/Cars/seedNormalize.ts --apply",

    "legacy:one": "ts-node -r tsconfig-paths/register src/scripts/maintenance/legacyToNested.ts",
    "legacy:scan": "ts-node -r tsconfig-paths/register src/scripts/maintenance/legacyToNested.ts",
    "legacy:scan:dry": "ts-node -r tsconfig-paths/register src/scripts/maintenance/legacyToNested.ts --dry",

    "seed:icons": "ts-node -r tsconfig-paths/register src/scripts/DatabaseImports/importIcons.ts",
    "seed:logos": "ts-node -r tsconfig-paths/register src/scripts/DatabaseImports/importLogos.ts",

    "progress:cars": "ts-node -r tsconfig-paths/register src/scripts/carConversionProgress.ts",
    "progress:cars:list": "ts-node -r tsconfig-paths/register src/scripts/carConversionProgress.ts --legacy",

    "ping:firebase": "ts-node -r tsconfig-paths/register src/scripts/pingFirestore.ts",
    "seed:diagnose": "ts-node -r tsconfig-paths/register src/scripts/Diagnosing/diagnoseCarSet.ts",

    "check:normalized-keys": "ts-node -r tsconfig-paths/register src/scripts/Diagnosing/checkNormalizedKeys.ts",

    "convert:car": "ts-node -r tsconfig-paths/register src/scripts/maintenance/convertToNewFormat.ts",
    "convert:car:dry": "ts-node -r tsconfig-paths/register src/scripts/maintenance/convertToNewFormat.ts --dry",

    "fill:stage-stats": "ts-node -r tsconfig-paths/register src/scripts/Placeholders/fillStageStats.ts",
    "fill:stage-stats:apply": "ts-node -r tsconfig-paths/register src/scripts/Placeholders/fillStageStats.ts --apply",
    "fill:stage-deltas": "ts-node -r tsconfig-paths/register src/scripts/Placeholders/fillStageDeltas.ts",
    "fill:stage-deltas:apply": "ts-node -r tsconfig-paths/register src/scripts/Placeholders/fillStageDeltas.ts --apply",
    "fill:import-deltas": "ts-node -r tsconfig-paths/register src/scripts/Placeholders/fillImportDeltas.ts",
    "fill:import-deltas:apply": "ts-node -r tsconfig-paths/register src/scripts/Placeholders/fillImportDeltas.ts --apply",

    "pull:submissions": "ts-node -r tsconfig-paths/register src/scripts/DatabaseImports/pullApprovedSubmissions.ts",
    "pull:submissions:dry": "ts-node -r tsconfig-paths/register src/scripts/DatabaseImports/pullApprovedSubmissions.ts --dry",

    "ts": "ts-node",
    "build": "tsc",
    "start:dev": "npm run start:watch"
  },
  "author": "Justin Hebenstreit",
  "license": "MIT",
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.1",
    "@types/express-rate-limit": "^5.1.3",
    "@types/helmet": "^0.0.48",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.18",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.5",
    "fast-glob": "^3.3.3",
    "inquirer": "^8.2.4",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "firebase-admin": "^13.6.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.4",
    "zod": "^4.1.12"
  }
}